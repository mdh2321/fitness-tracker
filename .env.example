# -------------------------------------------------------
# Turso (production database)
# Get these from https://app.turso.tech after creating a database
# Leave unset for local development (uses data/fitness.db)
# -------------------------------------------------------
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# -------------------------------------------------------
# Sync API Key
# A secret key used to authenticate the Apple Shortcuts sync.
# Generate any random string, e.g: openssl rand -hex 32
# Add the same value to your Shortcut and to Vercel env vars.
# -------------------------------------------------------
SYNC_API_KEY=your-secret-key-here
